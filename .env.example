# ─── Client (bundled — VITE_ prefix) ───────────────────────────────────────

# Local dev:

VITE_SITE_URL=http://localhost:5173

# Production (Cloudflare Worker):

# VITE_SITE_URL=https://velinstudiobd.com

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

VITE_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key



# ─── Server only (never expose to the browser) ───────────────────────────────

SUPABASE_SERVICE_ROLE_KEY=



# Cloudinary — admin media uploads (signed server-side upload)

# Dashboard: https://console.cloudinary.com/settings/api-keys

CLOUDINARY_CLOUD_NAME=

CLOUDINARY_API_KEY=

CLOUDINARY_API_SECRET=



# Optional — Supabase Management API (enable leaked-password protection)
# Create at: https://supabase.com/dashboard/account/tokens
# Requires Pro plan for password_hibp_enabled

SUPABASE_ACCESS_TOKEN=




